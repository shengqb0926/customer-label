{
  "name": "customer-label-performance-tests",
  "version": "1.0.0",
  "description": "Performance benchmark and load testing for Customer Label System",
  "scripts": {
    "benchmark": "jest --config ./test/jest-benchmark.json --runInBand",
    "benchmark:verbose": "jest --config ./test/jest-benchmark.json --verbose --runInBand",
    "benchmark:report": "node test/generate-benchmark-report.js",
    "load:test": "node test/load-test-runner.js",
    "stress:test": "node test/stress-test-runner.js",
    "performance:all": "npm run benchmark && npm run load:test"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "supertest": "^6.3.3",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1"
  }
}
